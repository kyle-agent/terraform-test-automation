# Copy to .env (or set in your shell) before running `MODE=integration make test`.

# Provider auth
export SCP_TF_ACCESS_KEY=""
export SCP_TF_SECRET_KEY=""
export SCP_TF_AUTH_URL="https://iam.s.samsungsdscloud.com/v1"
# Region: the provider reads SCP_TF_DEFAULT_REGION (per the registry docs).
# We also export the older SCP_DEFAULT_REGION alias from the same value so both
# conventions work. Keep them in sync.
export SCP_TF_DEFAULT_REGION="kr-west1"
export SCP_DEFAULT_REGION="${SCP_TF_DEFAULT_REGION}"
export SCP_ACCOUNT_ID=""

# Test fixtures — fill with ids that already exist in your test account so the
# tests don't have to bootstrap full VPC/subnet topology every time.
export TEST_VPC_ID=""
export TEST_SUBNET_ID=""
export TEST_SECURITY_GROUP_ID=""
export TEST_DBAAS_ENGINE_VERSION_ID=""
export TEST_SERVER_TYPE_NAME=""
export TEST_GPUNODE_ID=""

# Dynamic workflow knobs (optional)
# Fail the coverage guard if resource coverage drops below this percent.
# Leave unset for report-only. Ratchet upward as scenarios are added.
export COVERAGE_MIN=""
# Where reports are written (default: out). The dynamic pipeline shards this
# per chapter (out/<chapter>) so parallel runs don't clobber results.json.
export OUTPUT_DIR=""
